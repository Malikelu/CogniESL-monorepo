# Environment
.env

# Generated outputs
mnt/

# SQLite databases (runtime data — never commit)
*.db

# data/ has static YAML files (grammar, l1-interference, activities) that MUST be
# committed so Railway's Docker build can COPY them into the image.
# Only exclude runtime-generated subdirectories.
data/writing/

# Python
__pycache__/
*.pyc
venv/

# Node
node_modules/
webui/node_modules/

# Build artifacts
webui/out/
webui/.next/
.playwright-browsers/

# macOS
.DS_Store

# Intermediate slide artifacts
*.pptx.slides/